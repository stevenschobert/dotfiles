{
    // Workbench
    "workbench.settings.editor": "json",
    "workbench.startupEditor": "none",
    "workbench.editor.showTabs": "single",
    "workbench.editor.labelFormat": "long",

    // Breadcrumbs
    "breadcrumbs.enabled": false,

    // Explorer
    "explorer.openEditors.minVisible": 10,
    "explorer.openEditors.visible": 10,
    "explorer.autoReveal": "focusNoScroll",

    // Updates
    "update.mode": "start",

    // Git
    "git.openRepositoryInParentFolders": "never",

    // Extension
    "extensions.autoUpdate": false,
    "extensions.autoCheckUpdates": true,
    "extensions.ignoreRecommendations": true,

    // Telemetry
    "telemetry.telemetryLevel": "off",

    // Window
    "window.title": "${rootPath}",

    // Editor
    "editor.tabSize": 2,
    "editor.fontLigatures": true,
    "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.rulers": [
      90
    ],
    "editor.renderWhitespace": "selection",
    "editor.minimap.enabled": false,

    // Debugger
    "debug.console.fontFamily": "'MonaLisa Nerd Font', 'MonoLisa', monospace",
    "debug.console.fontSize": 14,
    "debug.inlineValues": "on",
    "debug.openDebug": "openOnSessionStart",
    "debug.showBreakpointsInOverviewRuler": true,
    "debug.toolBarLocation": "docked",
    "debug.console.acceptSuggestionOnEnter": "on",

    // Terminal
    "terminal.integrated.fontFamily": "'MonaLisa Nerd Font', 'MonoLisa', monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.letterSpacing": 1,

    // File handling
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    // Go
    "[go]": {
      "editor.tabSize": 4
    }
}
